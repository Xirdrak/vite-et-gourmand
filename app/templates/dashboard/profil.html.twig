{% extends 'base.html.twig' %}

{% block title %}Mon profil - Vite & Gourmand{% endblock %}

{% block body %}

<div class="container" style="padding-top: var(--space-lg); padding-bottom: var(--space-xl); max-width: 640px;">

    <a href="{{ path('app_dashboard') }}" class="back-link">
        <span class="material-symbols-outlined" aria-hidden="true">arrow_back</span>
        Retour a mon espace
    </a>

    <h1 class="text-headline-md" style="margin-bottom: var(--space-md);">Mon profil</h1>

    {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}

    <section class="order-section">
        <h2 class="order-section__title">Informations personnelles</h2>
        <div class="order-info-grid">
            <div class="form-group">
                {{ form_label(form.prenom) }}
                {{ form_widget(form.prenom, {attr: {class: 'form-input'}}) }}
                {{ form_errors(form.prenom) }}
            </div>
            <div class="form-group">
                {{ form_label(form.nom) }}
                {{ form_widget(form.nom, {attr: {class: 'form-input'}}) }}
                {{ form_errors(form.nom) }}
            </div>
        </div>
        <div class="form-group">
            {{ form_label(form.email) }}
            {{ form_widget(form.email, {attr: {class: 'form-input'}}) }}
            {{ form_errors(form.email) }}
        </div>
        <div class="form-group">
            {{ form_label(form.telephone) }}
            {{ form_widget(form.telephone, {attr: {class: 'form-input'}}) }}
            {{ form_errors(form.telephone) }}
        </div>
    </section>

    <section class="order-section" style="margin-top: var(--space-md);">
        <h2 class="order-section__title">Adresse</h2>
        <div class="form-group">
            {{ form_label(form.adressePostale) }}
            {{ form_widget(form.adressePostale, {attr: {class: 'form-input'}}) }}
            {{ form_errors(form.adressePostale) }}
        </div>
        <div class="order-info-grid">
            <div class="form-group">
                {{ form_label(form.ville) }}
                {{ form_widget(form.ville, {attr: {class: 'form-input'}}) }}
                {{ form_errors(form.ville) }}
            </div>
            <div class="form-group">
                {{ form_label(form.pays) }}
                {{ form_widget(form.pays, {attr: {class: 'form-input'}}) }}
                {{ form_errors(form.pays) }}
            </div>
        </div>
    </section>

    <div class="form-actions">
        <button type="submit" class="btn-primary">
            Enregistrer les modifications
        </button>
    </div>

    {{ form_end(form) }}

</div>

{% endblock %}
