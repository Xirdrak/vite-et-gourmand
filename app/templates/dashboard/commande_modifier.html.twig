{% extends 'base.html.twig' %}

{% block title %}Modifier la commande {{ commande.numeroCommande }} - Vite & Gourmand{% endblock %}

{% block body %}

<div class="container" style="padding-top: var(--space-lg); padding-bottom: var(--space-xl);">

    <a href="{{ path('app_dashboard_commande', {id: commande.id}) }}" class="back-link">
        <span class="material-symbols-outlined" aria-hidden="true">arrow_back</span>
        Retour au detail
    </a>

    <h1 class="text-headline-md" style="margin-bottom: var(--space-md);">
        Modifier la commande {{ commande.numeroCommande }}
    </h1>

    <div class="order-layout">

        <div class="order-form-wrapper">

            {{ form_start(form, {attr: {novalidate: 'novalidate', id: 'commande-form'}}) }}

            <section class="order-section">
                <h2 class="order-section__title">Le menu</h2>
                <div class="form-group">
                    <label class="form-label">Menu sélectionné</label>
                    <input type="text" class="form-input" value="{{ commande.menu.titre }}" readonly>
                    <small class="form-hint">Le menu ne peut pas être modifié après la commande.</small>
                </div>

                <div class="form-group">
                    {{ form_label(form.nombre_personne) }}
                    {{ form_widget(form.nombre_personne, {attr: {class: 'form-input'}}) }}
                    {{ form_errors(form.nombre_personne) }}
                    <small id="min-personnes-hint" class="form-hint" style="display:none;"></small>
                </div>
            </section>

            <section class="order-section">
                <h2 class="order-section__title">La prestation</h2>

                <div class="order-info-grid">
                    <div class="form-group">
                        {{ form_label(form.date_prestation) }}
                        {{ form_widget(form.date_prestation, {attr: {class: 'form-input'}}) }}
                        {{ form_errors(form.date_prestation) }}
                    </div>
                    <div class="form-group">
                        {{ form_label(form.heure_livraison) }}
                        {{ form_widget(form.heure_livraison, {attr: {class: 'form-input'}}) }}
                        {{ form_errors(form.heure_livraison) }}
                    </div>
                </div>

                <div class="form-group">
                    {{ form_label(form.adresse_livraison) }}
                    {{ form_widget(form.adresse_livraison, {attr: {class: 'form-input'}}) }}
                    {{ form_errors(form.adresse_livraison) }}
                </div>

                <div class="form-group">
                    {{ form_label(form.ville_livraison) }}
                    {{ form_widget(form.ville_livraison, {attr: {class: 'form-input'}}) }}
                    {{ form_errors(form.ville_livraison) }}
                </div>

                <div class="form-group" style="display:flex; align-items:center; gap: var(--space-sm);">
                    {{ form_widget(form.hors_bordeaux) }}
                    {{ form_label(form.hors_bordeaux) }}
                </div>

                <div class="form-group" id="km-field" style="display:{{ form.vars.value['hors_bordeaux'] ?? false ? 'block' : 'none' }};">
                    {{ form_label(form.nombre_km) }}
                    {{ form_widget(form.nombre_km, {attr: {class: 'form-input'}}) }}
                    {{ form_errors(form.nombre_km) }}
                    <small class="form-hint">Supplément : 5 € + 0,59 € par km</small>
                </div>
            </section>

            <button type="submit" class="btn-primary" style="width:100%; margin-top: var(--space-md);">
                Enregistrer les modifications
            </button>

            {{ form_end(form) }}

        </div>

        <aside class="order-summary" id="order-summary">
            <div class="order-summary__card">
                <h2 class="order-section__title">Récapitulatif</h2>

                <div class="order-summary__lines">
                    <div class="order-summary__line">
                        <span>Prix menu</span>
                        <span id="summary-prix-menu">-</span>
                    </div>
                    <div class="order-summary__line" id="summary-livraison-line" style="display:none;">
                        <span>Livraison</span>
                        <span id="summary-prix-livraison">-</span>
                    </div>
                    <div class="order-summary__line order-summary__line--reduction" id="summary-reduction-line" style="display:none;">
                        <span>Réduction 10% (groupe)</span>
                        <span id="summary-reduction">-</span>
                    </div>
                    <div class="order-summary__total">
                        <span>Total</span>
                        <span id="summary-total">-</span>
                    </div>
                </div>

                <p class="order-summary__note">
                    <span class="material-symbols-outlined" aria-hidden="true">info</span>
                    Réduction de 10% applicable à partir de {{ commande.menu.nombrePersonneMinimum + 5 }} personnes.
                </p>
            </div>
        </aside>

    </div>

</div>

{% endblock %}

{% block javascripts %}
<script>
    const menuData    = {{ menu_data|json_encode|raw }};
    const nbPersonnes = document.getElementById('commande_modification_nombre_personne');
    const horsBo      = document.getElementById('commande_modification_hors_bordeaux');
    const kmField     = document.getElementById('km-field');
    const nbKm        = document.getElementById('commande_modification_nombre_km');
    const minHint     = document.getElementById('min-personnes-hint');

    function fmt(n) {
        return n.toFixed(2).replace('.', ',') + ' €';
    }

    function recalculer() {
        const nb   = parseInt(nbPersonnes ? nbPersonnes.value : 0) || 0;
        const hors = horsBo ? horsBo.checked : false;
        const km   = parseInt(nbKm ? nbKm.value : 0) || 0;

        if (nb <= 0) {
            document.getElementById('summary-prix-menu').textContent = '-';
            document.getElementById('summary-total').textContent     = '-';
            return;
        }

        const min  = menuData.minimum;
        const prix = menuData.prix_par_personne;

        if (minHint) {
            minHint.textContent   = 'Minimum requis : ' + min + ' personnes.';
            minHint.style.display = nb < min ? 'block' : 'none';
        }

        let prixMenu  = prix * nb;
        let reduction = 0;

        if (nb >= min + 5) {
            reduction = prixMenu * 0.1;
            prixMenu  = prixMenu * 0.9;
            document.getElementById('summary-reduction-line').style.display = 'flex';
            document.getElementById('summary-reduction').textContent        = '-' + fmt(reduction);
        } else {
            document.getElementById('summary-reduction-line').style.display = 'none';
        }

        let prixLivraison = 0;
        if (hors) {
            prixLivraison = 5 + (0.59 * km);
            document.getElementById('summary-livraison-line').style.display = 'flex';
            document.getElementById('summary-prix-livraison').textContent   = fmt(prixLivraison);
        } else {
            document.getElementById('summary-livraison-line').style.display = 'none';
        }

        document.getElementById('summary-prix-menu').textContent = fmt(prixMenu);
        document.getElementById('summary-total').textContent     = fmt(prixMenu + prixLivraison);
    }

    if (nbPersonnes) nbPersonnes.addEventListener('input', recalculer);
    if (horsBo) {
        horsBo.addEventListener('change', function () {
            kmField.style.display = this.checked ? 'block' : 'none';
            recalculer();
        });
    }
    if (nbKm) nbKm.addEventListener('input', recalculer);

    recalculer();
</script>
{% endblock %}
