{% extends 'base.html.twig' %}

{% block title %}Commande confirmée - Vite & Gourmand{% endblock %}

{% block body %}

<div class="container" style="padding-top: var(--space-xl); padding-bottom: var(--space-xl); text-align:center;">

    <div class="order-confirmation">

        <span class="material-symbols-outlined order-confirmation__icon" aria-hidden="true">check_circle</span>

        <h1 class="text-headline-md" style="margin-top: var(--space-md);">Commande enregistree !</h1>

        <p style="color: var(--color-on-surface-variant); margin-top: var(--space-sm); font-size: var(--fs-body-lg);">
            Votre commande <strong>{{ numero_commande }}</strong> a bien ete prise en compte.
        </p>

        <p style="color: var(--color-on-surface-variant); margin-top: var(--space-xs);">
            Un email de confirmation vous a ete envoye. Notre equipe va etudier votre demande et vous recontactera.
        </p>

        <div style="margin-top: var(--space-lg); display:flex; gap: var(--space-sm); justify-content:center; flex-wrap:wrap;">
            <a href="{{ path('app_menus') }}" class="btn-secondary">Voir les menus</a>
            <a href="{{ path('app_homepage') }}" class="btn-primary">Retour a l'accueil</a>
        </div>

    </div>

</div>

{% endblock %}
