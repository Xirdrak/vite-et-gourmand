{% extends 'admin/layout.html.twig' %}

{% block title %}Nouveau compte employé - Vite & Gourmand{% endblock %}

{% block admin_title %}Créer un compte employé{% endblock %}
{% block admin_subtitle %}Le nouvel employé recevra un mail de notification sans le mot de passe.{% endblock %}

{% block admin_action %}
    <a href="{{ path('app_admin_employes') }}" class="back-link">
        <span class="material-symbols-outlined" aria-hidden="true">arrow_back</span>
        Retour
    </a>
{% endblock %}

{% block admin_content %}

{{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}

<div style="max-width: 480px;">
    <section class="order-section">

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-md);">
            <div class="form-group">
                {{ form_label(form.prenom, null, {label_attr: {class: 'form-label'}}) }}
                {{ form_widget(form.prenom, {attr: {class: 'form-input'}}) }}
                {{ form_errors(form.prenom) }}
            </div>
            <div class="form-group">
                {{ form_label(form.nom, null, {label_attr: {class: 'form-label'}}) }}
                {{ form_widget(form.nom, {attr: {class: 'form-input'}}) }}
                {{ form_errors(form.nom) }}
            </div>
        </div>

        <div class="form-group">
            {{ form_label(form.email, null, {label_attr: {class: 'form-label'}}) }}
            {{ form_widget(form.email, {attr: {class: 'form-input'}}) }}
            {{ form_errors(form.email) }}
        </div>

        <div class="form-group" style="margin-top: var(--space-md);">
            {{ form_label(form.mot_de_passe.first, null, {label_attr: {class: 'form-label'}}) }}
            {{ form_widget(form.mot_de_passe.first, {attr: {class: 'form-input'}}) }}
            {{ form_errors(form.mot_de_passe.first) }}
        </div>

        <div class="form-group" style="margin-top: var(--space-md);">
            {{ form_label(form.mot_de_passe.second, null, {label_attr: {class: 'form-label'}}) }}
            {{ form_widget(form.mot_de_passe.second, {attr: {class: 'form-input'}}) }}
            {{ form_errors(form.mot_de_passe) }}
        </div>

        <small class="form-hint" style="margin-top: var(--space-xs); display: block;">
            Communiquez le mot de passe à l'employé en personne — il ne sera pas envoyé par mail.
        </small>

    </section>

    <div style="margin-top: var(--space-lg); display: flex; gap: var(--space-sm);">
        <button type="submit" class="btn-primary">
            <span class="material-symbols-outlined" aria-hidden="true">person_add</span>
            Créer le compte
        </button>
        <a href="{{ path('app_admin_employes') }}" class="btn-secondary">Annuler</a>
    </div>
</div>

{{ form_end(form) }}

{% endblock %}
