{% extends 'base.html.twig' %}

{% block title %}Inscription - Vite & Gourmand{% endblock %}

{% block body %}
<div class="page-auth">
    <div class="auth-card auth-card--wide">
        <h1 class="auth-card__title">Créer un compte</h1>

        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

        {{ include('_form_errors_alert.html.twig', {form: form}) }}

        <div class="grid-2">
            <div class="form-group">
                {{ form_label(form.prenom) }}
                {{ form_widget(form.prenom) }}
                {{ form_errors(form.prenom) }}
            </div>
            <div class="form-group">
                {{ form_label(form.nom) }}
                {{ form_widget(form.nom) }}
                {{ form_errors(form.nom) }}
            </div>
        </div>

        <div class="form-group">
            {{ form_label(form.email) }}
            {{ form_widget(form.email) }}
            {{ form_errors(form.email) }}
        </div>

        <div class="form-group">
            {{ form_label(form.telephone) }}
            {{ form_widget(form.telephone) }}
            {{ form_errors(form.telephone) }}
        </div>

        <div class="form-group">
            {{ form_label(form.adressePostale) }}
            {{ form_widget(form.adressePostale) }}
            {{ form_errors(form.adressePostale) }}
        </div>

        <div class="grid-2">
            <div class="form-group">
                {{ form_label(form.ville) }}
                {{ form_widget(form.ville) }}
                {{ form_errors(form.ville) }}
            </div>
            <div class="form-group">
                {{ form_label(form.pays) }}
                {{ form_widget(form.pays) }}
                {{ form_errors(form.pays) }}
            </div>
        </div>

        <div class="form-group">
            {{ form_label(form.plainPassword.first) }}
            {{ form_widget(form.plainPassword.first) }}
            <span class="form-hint">10 caractères minimum, 1 majuscule, 1 minuscule, 1 chiffre, 1 caractère spécial.</span>
        </div>
        <div class="form-group">
            {{ form_label(form.plainPassword.second) }}
            {{ form_widget(form.plainPassword.second) }}
            {{ form_errors(form.plainPassword) }}
        </div>

        <button type="submit" class="btn-primary btn-full">Créer mon compte</button>
        {{ form_end(form) }}

        <div class="auth-card__footer">
            Déjà un compte ? <a href="{{ path('app_login') }}">Se connecter</a>
        </div>
    </div>
</div>
{% endblock %}
