<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Vite & Gourmand{% endblock %}</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    {% block stylesheets %}{% endblock %}
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand fw-bold" href="{{ path('app_homepage') }}">Vite & Gourmand</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navMain">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_homepage') }}">Accueil</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Nos menus</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Contact</a></li>
                </ul>
                <ul class="navbar-nav">
                    {% if app.user %}
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                {{ app.user.nomComplet }}
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" href="#">Mon espace</a></li>
                                {% if is_granted('ROLE_EMPLOYE') %}
                                    <li><a class="dropdown-item" href="#">Espace employe</a></li>
                                {% endif %}
                                {% if is_granted('ROLE_ADMIN') %}
                                    <li><a class="dropdown-item" href="#">Administration</a></li>
                                {% endif %}
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form method="post" action="{{ path('app_logout') }}">
                                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}">
                                        <button type="submit" class="dropdown-item border-0 bg-transparent w-100 text-start">Deconnexion</button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    {% else %}
                        <li class="nav-item"><a class="nav-link" href="{{ path('app_login') }}">Connexion</a></li>
                        <li class="nav-item"><a class="nav-link" href="{{ path('app_register') }}">Inscription</a></li>
                    {% endif %}
                </ul>
            </div>
        </div>
    </nav>

    <main class="container my-4">
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ type == 'error' ? 'danger' : type }} alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
        {% endfor %}

        {% block body %}{% endblock %}
    </main>

    <footer class="bg-dark text-light py-5 mt-5">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-4">
                    <h6 class="text-uppercase fw-bold mb-3">Vite & Gourmand</h6>
                    <p class="text-secondary small">Traiteur evenementiel a Bordeaux depuis 1999.</p>
                </div>
                <div class="col-md-4">
                    <h6 class="text-uppercase fw-bold mb-3">Nos horaires</h6>
                    <ul class="list-unstyled small text-secondary">
                        {% for horaire in get_horaires() %}
                            <li class="d-flex justify-content-between">
                                <span>{{ horaire.jour }}</span>
                                <span>{{ horaire.heureOuverture|date('H:i') }} - {{ horaire.heureFermeture|date('H:i') }}</span>
                            </li>
                        {% endfor %}
                    </ul>
                </div>
                <div class="col-md-4">
                    <h6 class="text-uppercase fw-bold mb-3">Informations</h6>
                    <ul class="list-unstyled small">
                        <li><a class="text-secondary text-decoration-none" href="#">Mentions legales</a></li>
                        <li><a class="text-secondary text-decoration-none" href="#">CGV</a></li>
                        <li><a class="text-secondary text-decoration-none" href="#">Contact</a></li>
                    </ul>
                </div>
            </div>
            <hr class="border-secondary mt-4">
            <p class="text-center text-secondary small mb-0">&copy; {{ 'now'|date('Y') }} Vite & Gourmand - Tous droits reserves</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    {% block javascripts %}{% endblock %}
</body>
</html>
