{% extends 'base.html.twig' %}

{% block title %}Nos menus - Vite & Gourmand{% endblock %}

{% block body %}

<div class="container" style="padding-top: var(--space-lg); padding-bottom: var(--space-xl);">

    <div class="d-flex justify-between align-center" style="margin-bottom: var(--space-md);">
        <h1 class="text-headline-md">Nos menus</h1>
        <span style="font-size: var(--fs-label-md); color: var(--color-on-surface-variant);" id="compteur-menus">
            {{ menus|length }} menu{{ menus|length > 1 ? 's' : '' }}
        </span>
    </div>

    <div class="filter-sidebar" style="margin-bottom: var(--space-lg);">
        <div class="grid-2" style="gap: var(--space-md);">
            <div class="form-group" style="margin-bottom:0;">
                <label for="filter-theme">Thème</label>
                <select id="filter-theme" class="form-select">
                    <option value="">Tous les thèmes</option>
                    {% for theme in themes %}
                        <option value="{{ theme.id }}">{{ theme.libelle }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="form-group" style="margin-bottom:0;">
                <label for="filter-regime">Régime</label>
                <select id="filter-regime" class="form-select">
                    <option value="">Tous les régimes</option>
                    {% for regime in regimes %}
                        <option value="{{ regime.id }}">{{ regime.libelle }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="form-group" style="margin-bottom:0;">
                <label for="filter-prix-max">
                    Prix max par personne : <strong id="label-prix-max">sans limite</strong>
                </label>
                <input type="range" id="filter-prix-max" class="form-input-range"
                       min="0" max="200" step="5" value="200">
            </div>
            <div class="form-group" style="margin-bottom:0;">
                <label for="filter-nb-personnes">Nombre de personnes</label>
                <input type="number" id="filter-nb-personnes" placeholder="ex. 15" min="1">
            </div>
        </div>
        <div style="margin-top: var(--space-md);">
            <button type="button" id="btn-reset" class="btn-ghost" style="padding: var(--space-xs) var(--space-md);">
                Réinitialiser les filtres
            </button>
        </div>
    </div>

    <div class="grid-3" id="grille-menus">
        {% for menu in menus %}
            <div class="menu-col"
                 data-theme-id="{{ menu.theme.id }}"
                 data-regime-id="{{ menu.regime.id }}"
                 data-prix="{{ menu.prixParPersonne }}"
                 data-nb-min="{{ menu.nombrePersonneMinimum }}">
                <div class="card-menu">
                    <div class="card-menu__image-wrapper">
                        {% if menu.images is not empty %}
                            <img class="card-menu__image"
                                 src="{{ menu.images.first.chemin }}"
                                 alt="{{ menu.titre }}">
                        {% else %}
                            <div class="card-menu__placeholder">🍽️</div>
                        {% endif %}
                        <div class="card-menu__badges">
                            <span class="badge badge--{{ menu.theme.libelle|lower|replace({' ': '-', 'â': 'a', 'ô': 'o', 'é': 'e', 'è': 'e', 'ê': 'e', 'î': 'i', 'û': 'u', 'ï': 'i', 'ë': 'e', 'ü': 'u'}) }}">
                                {{ menu.theme.libelle }}
                            </span>
                            <span class="badge badge--{{ menu.regime.libelle|lower|replace({' ': '-', 'â': 'a', 'ô': 'o', 'é': 'e', 'è': 'e', 'ê': 'e', 'î': 'i', 'û': 'u', 'ï': 'i', 'ë': 'e', 'ü': 'u'}) }}">
                                {{ menu.regime.libelle }}
                            </span>
                        </div>
                    </div>
                    <div class="card-menu__body">
                        <h2 class="card-menu__title">{{ menu.titre }}</h2>
                        <p class="card-menu__description">{{ menu.description }}</p>
                        <div class="card-menu__meta">
                            <div>
                                <p class="card-menu__price">{{ menu.prixParPersonne }}€ / pers.</p>
                                <p class="card-menu__persons">Min. {{ menu.nombrePersonneMinimum }} personnes</p>
                            </div>
                            <a href="{{ path('app_menu_show', {id: menu.id}) }}" class="btn-ghost" style="padding: var(--space-xs) var(--space-sm); font-size: var(--fs-label-sm);">
                                Voir le menu
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        {% else %}
            <p class="text-center text-muted" style="grid-column: 1/-1; padding: var(--space-xl) 0;">
                Aucun menu disponible pour le moment.
            </p>
        {% endfor %}
    </div>

    <p class="text-center text-muted" id="msg-aucun-resultat" style="display:none; padding: var(--space-xl) 0;">
        Aucun menu ne correspond à vos critères.
    </p>

</div>

{% endblock %}

{% block javascripts %}
<script>
(function () {
    var cols      = document.querySelectorAll('.menu-col');
    var selTheme  = document.getElementById('filter-theme');
    var selRegime = document.getElementById('filter-regime');
    var rangePrix = document.getElementById('filter-prix-max');
    var inputNb   = document.getElementById('filter-nb-personnes');
    var labelPrix = document.getElementById('label-prix-max');
    var compteur  = document.getElementById('compteur-menus');
    var msgAucun  = document.getElementById('msg-aucun-resultat');
    var btnReset  = document.getElementById('btn-reset');

    function updateLabelPrix() {
        var val = parseInt(rangePrix.value);
        labelPrix.textContent = val >= 200 ? 'sans limite' : val + '€';
    }

    function filtrer() {
        var themeId  = selTheme.value;
        var regimeId = selRegime.value;
        var prixMax  = parseInt(rangePrix.value);
        var nbMin    = parseInt(inputNb.value) || 0;
        var visibles = 0;

        cols.forEach(function (col) {
            var matchTheme  = !themeId  || col.dataset.themeId  === themeId;
            var matchRegime = !regimeId || col.dataset.regimeId === regimeId;
            var matchPrix   = prixMax >= 200 || parseFloat(col.dataset.prix) <= prixMax;
            var matchNb     = nbMin === 0 || parseInt(col.dataset.nbMin) <= nbMin;
            var visible     = matchTheme && matchRegime && matchPrix && matchNb;
            col.style.display = visible ? '' : 'none';
            if (visible) visibles++;
        });

        compteur.textContent = visibles + ' menu' + (visibles > 1 ? 's' : '');
        msgAucun.style.display = visibles === 0 ? 'block' : 'none';
    }

    function reset() {
        selTheme.value  = '';
        selRegime.value = '';
        rangePrix.value = 200;
        inputNb.value   = '';
        updateLabelPrix();
        filtrer();
    }

    rangePrix.addEventListener('input', function () { updateLabelPrix(); filtrer(); });
    selTheme.addEventListener('change', filtrer);
    selRegime.addEventListener('change', filtrer);
    inputNb.addEventListener('input', filtrer);
    btnReset.addEventListener('click', reset);

    updateLabelPrix();
})();
</script>
{% endblock %}
