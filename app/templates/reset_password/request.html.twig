{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié - Vite & Gourmand{% endblock %}

{% block body %}
<div class="page-auth">
    <div class="auth-card">
        <h1 class="auth-card__title">Mot de passe oublié</h1>
        <p style="color: var(--color-on-surface-variant); margin-bottom: var(--space-md);">
            Saisissez votre adresse e-mail. Si un compte existe, vous recevrez un lien de réinitialisation valable 1 heure.
        </p>

        {{ form_start(form) }}
        <div class="form-group">
            {{ form_label(form.email) }}
            {{ form_widget(form.email) }}
            {{ form_errors(form.email) }}
        </div>
        <button type="submit" class="btn-primary btn-full">Envoyer le lien</button>
        {{ form_end(form) }}

        <div class="auth-card__footer">
            <a href="{{ path('app_login') }}">Retour à la connexion</a>
        </div>
    </div>
</div>
{% endblock %}
