{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublie — Vite & Gourmand{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-5">
        <h1 class="h3 mb-4">Mot de passe oublie</h1>
        <p class="text-muted mb-4">Saisissez votre adresse e-mail. Si un compte existe, vous recevrez un lien de reinitialisation valable 1 heure.</p>

        {{ form_start(form) }}
        <div class="mb-3">
            {{ form_label(form.email) }}
            {{ form_widget(form.email, {'attr': {'class': 'form-control' ~ (form.email.vars.errors|length ? ' is-invalid' : '')}}) }}
            {{ form_errors(form.email) }}
        </div>
        <button type="submit" class="btn btn-dark w-100">Envoyer le lien</button>
        {{ form_end(form) }}

        <div class="mt-3 text-center">
            <a href="{{ path('app_login') }}">Retour a la connexion</a>
        </div>
    </div>
</div>
{% endblock %}
