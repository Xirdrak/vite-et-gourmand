{% extends 'base.html.twig' %}

{% block title %}Nouveau mot de passe - Vite & Gourmand{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-5">
        <h1 class="h3 mb-4">Choisir un nouveau mot de passe</h1>

        {{ form_start(form) }}
        <div class="mb-3">
            {{ form_label(form.plainPassword.first) }}
            {{ form_widget(form.plainPassword.first, {'attr': {'class': 'form-control' ~ (form.plainPassword.vars.errors|length ? ' is-invalid' : '')}}) }}
            <small class="text-muted">10 caracteres minimum, 1 majuscule, 1 minuscule, 1 chiffre, 1 caractere special.</small>
        </div>
        <div class="mb-3">
            {{ form_label(form.plainPassword.second) }}
            {{ form_widget(form.plainPassword.second, {'attr': {'class': 'form-control' ~ (form.plainPassword.vars.errors|length ? ' is-invalid' : '')}}) }}
            {{ form_errors(form.plainPassword) }}
        </div>
        <input type="hidden" name="token" value="{{ token }}">
        <button type="submit" class="btn btn-dark w-100">Enregistrer le mot de passe</button>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
