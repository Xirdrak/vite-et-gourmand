{% extends 'base.html.twig' %}

{% block title %}Nouveau mot de passe - Vite & Gourmand{% endblock %}

{% block body %}
<div class="page-auth">
    <div class="auth-card">
        <h1 class="auth-card__title">Choisir un nouveau mot de passe</h1>

        {{ form_start(form) }}
        <div class="form-group">
            {{ form_label(form.plainPassword.first) }}
            {{ form_widget(form.plainPassword.first) }}
            <span class="form-hint">10 caractères minimum, 1 majuscule, 1 minuscule, 1 chiffre, 1 caractère spécial.</span>
        </div>
        <div class="form-group">
            {{ form_label(form.plainPassword.second) }}
            {{ form_widget(form.plainPassword.second) }}
            {{ form_errors(form.plainPassword) }}
        </div>
        <input type="hidden" name="token" value="{{ token }}">
        <button type="submit" class="btn-primary btn-full">Enregistrer le mot de passe</button>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
